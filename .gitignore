# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# --- DATABASE & PRISMA ---
# Ignore the actual SQLite database file
*.db
*.db-journal

# Ignore Prisma's generated folder if you don't want it in Git
# (Usually fine to ignore as it's regenerated on npm install)
/node_modules/.prisma

# Ensure environment variables are strictly ignored
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
